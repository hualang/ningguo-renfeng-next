# 正式站根地址，无尾斜杠；用于 SEO（canonical、sitemap、OG 等）。本地可不设，默认 http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://www.your-domain.com

# 在 https://www.sanity.io/manage 创建项目后填入 Project ID（公开，可进前端 bundle）
NEXT_PUBLIC_SANITY_PROJECT_ID=

# 通常为 production；与 Sanity 项目里实际 dataset 名称一致
NEXT_PUBLIC_SANITY_DATASET=production

# 可选；默认与 next-sanity 推荐一致
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# 若 dataset 为 private 或需要预览草稿时再配置（勿提交到 Git）
# SANITY_API_READ_TOKEN=

# —— 询盘邮件（Resend: https://resend.com 注册后创建 API Key）——
# RESEND_API_KEY=re_xxxx
# 收件人，多个用英文逗号分隔
# INQUIRY_TO_EMAIL=sales@yourdomain.com
# 发件人（需在 Resend 验证域名；测试可用 Resend 文档中的 onboarding 地址）
# INQUIRY_FROM_EMAIL=Renfeng Web <onboarding@resend.dev>

# —— 飞书多维表格（可选）：在表格「自动化」里用 Webhook 触发器生成地址后填入 ——
# FEISHU_BITABLE_WEBHOOK_URL=
# 请求体 JSON 字段：name, company, email, phone, country, message, locale, submittedAt
